# Stadia Maps API key for the rat and pothole maps.
# Sign up free at https://stadiamaps.com → Create Property → Authentication Configuration
# Add localhost:3000 and your Vercel domain to the allowed Property origins.
# The NEXT_PUBLIC_ prefix is required so the key is accessible to client-side Leaflet.
NEXT_PUBLIC_STADIA_API_KEY=your-key-here --- IGNORE ---
